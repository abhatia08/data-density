# Databricks workspace
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com

# Secret scope for ETL storage credentials (used by dbutils.secrets.get)
SECRET_SCOPE=<secret-scope-name>
STORAGE_ACCOUNT_KEY=<secret-key-name>

# Pretrained GMM bundle paths (cohort 2a/2b inference)
# Default fallback: /dbfs/mnt/models/cohort_1/{gmm_4,gmm_7}/
GMM_4_MODEL_URI=
GMM_7_MODEL_URI=
